# ============================================================
# 🏗️ GROUND TRUTH CLASSIFICATION — 242 Eligible T2D Patients
#
# Builds FOUR ground truth versions:
#   1. Two-tier  (SEVERE / NOT_SEVERE) — primary, no HbA1c
#   2. Two-tier  (SEVERE / NOT_SEVERE) — sensitivity, with HbA1c
#   3. Four-tier (Mild/Moderate/Severe/Critical-Complex) — primary
#   4. Four-tier (Mild/Moderate/Severe/Critical-Complex) — sensitivity
#
# All based on Cooper et al. (2025) green-rated T2D phenotypes.
# HbA1c (amber, 7.58) added only in sensitivity analysis.
#
# STEP 1: Audit — build per-patient dimension table
# STEP 2: Classify — apply tier rules
# STEP 3: Compare — how many change when HbA1c is added?
# STEP 4: Save — sealed Excel with all versions + evidence
# ============================================================

import pandas as pd
import numpy as np
from datetime import datetime

# ── PATHS ─────────────────────────────────────────────────────
BASE_PATH = "/content/drive/MyDrive/THESIS/Data/Coherent_data/"
COHORT_PATH = BASE_PATH + "t2d_fully_eligible_cohort.csv"

print("=" * 70)
print("🏗️ GROUND TRUTH CLASSIFICATION — Cooper et al. (2025)")
print("   Primary (Green phenotypes) + Sensitivity (+ HbA1c)")
print("=" * 70)

# ── 1. Load cohort and data ───────────────────────────────────
print("\n📥 Loading data...")
cohort = pd.read_csv(COHORT_PATH)
patient_ids = cohort["PATIENT_ID_x"].unique()
N = len(patient_ids)
print(f"   Cohort: {N} patients")

conditions   = pd.read_csv(BASE_PATH + "conditions.csv")
observations = pd.read_csv(BASE_PATH + "observations.csv")
medications  = pd.read_csv(BASE_PATH + "medications.csv")

# Try loading procedures too
try:
    procedures = pd.read_csv(BASE_PATH + "procedures.csv")
    has_procedures = True
except:
    procedures = pd.DataFrame()
    has_procedures = False
    print("   ⚠️  procedures.csv not found — skipping amputation check")

# Filter to cohort patients
con = conditions[conditions["PATIENT"].isin(patient_ids)]
obs = observations[observations["PATIENT"].isin(patient_ids)]
med = medications[medications["PATIENT"].isin(patient_ids)]
if has_procedures:
    proc = procedures[procedures["PATIENT"].isin(patient_ids)]

print(f"   Conditions: {len(con):,} rows")
print(f"   Observations: {len(obs):,} rows")
print(f"   Medications: {len(med):,} rows")
if has_procedures:
    print(f"   Procedures: {len(proc):,} rows")
print(f"✅ Data loaded and filtered.")

# ══════════════════════════════════════════════════════════════
# AUDIT: Show unique descriptions per table (for verification)
# ══════════════════════════════════════════════════════════════
print(f"\n{'=' * 70}")
print("📋 UNIQUE DESCRIPTIONS IN COHORT PATIENTS")
print("   Review these to verify keyword matching is correct")
print("=" * 70)

for name, df in [("conditions", con), ("observations", obs), ("medications", med)]:
    descs = df["DESCRIPTION"].dropna().unique()
    desc_counts = df.groupby("DESCRIPTION")["PATIENT"].nunique().sort_values(ascending=False)
    print(f"\n{'─' * 70}")
    print(f"📌 {name.upper()} — {len(descs)} unique descriptions")
    print(f"{'─' * 70}")
    for d, n in desc_counts.items():
        pct = 100 * n / N
        print(f"   {n:>5} pts ({pct:5.1f}%)  {d}")

if has_procedures:
    proc_descs = proc["DESCRIPTION"].dropna().unique()
    proc_counts = proc.groupby("DESCRIPTION")["PATIENT"].nunique().sort_values(ascending=False)
    print(f"\n{'─' * 70}")
    print(f"📌 PROCEDURES — {len(proc_descs)} unique descriptions")
    print(f"{'─' * 70}")
    for d, n in proc_counts.items():
        pct = 100 * n / N
        print(f"   {n:>5} pts ({pct:5.1f}%)  {d}")

# ══════════════════════════════════════════════════════════════
# STEP 1: BUILD PER-PATIENT DIMENSION TABLE
# ══════════════════════════════════════════════════════════════
print(f"\n{'=' * 70}")
print("📊 STEP 1 — Auditing Cooper phenotypes + Building dimension table")
print("=" * 70)

# ── D1: Complication count ────────────────────────────────────
print(f"\n{'─' * 70}")
print("🟢 D1 — MICROVASCULAR COMPLICATIONS (Cooper #1, score 8.75)")
print(f"{'─' * 70}")
COMPLICATION_SEARCH = {
    "Nephropathy / CKD": [
        "nephropathy", "kidney", "renal", "ckd", "chronic kidney"
    ],
    "Retinopathy": [
        "retinopathy", "retinal", "macular"
    ],
    "Neuropathy": [
        "neuropathy", "nerve"
    ],
    "Foot ulcer / Amputation": [
        "foot ulcer", "amputation", "gangrene"
    ],
    "Stroke / Cerebrovascular": [
        "stroke", "cerebrovascular", "tia", "transient ischemic"
    ],
    "Coronary / MI": [
        "coronary", "myocardial infarction", "heart attack",
        "ischemic heart", "angina"
    ],
    "Heart failure": [
        "heart failure", "cardiac failure"
    ],
    "Peripheral vascular": [
        "peripheral vascular", "peripheral arterial", "claudication"
    ],
}

patient_complications = {}
for comp_type, keywords in COMPLICATION_SEARCH.items():
    mask = con["DESCRIPTION"].str.contains("|".join(keywords), case=False, na=False)
    for p in con[mask]["PATIENT"].unique():
        if p not in patient_complications:
            patient_complications[p] = set()
        patient_complications[p].add(comp_type)

print(f"\n{'Complication type':<30} {'N patients':>12} {'%':>8}  Matching descriptions")
print("-" * 95)
for comp_type, keywords in COMPLICATION_SEARCH.items():
    mask = con["DESCRIPTION"].str.contains("|".join(keywords), case=False, na=False)
    matching_descs = con[mask]["DESCRIPTION"].unique()
    pts_n = con[mask]["PATIENT"].nunique()
    print(f"{comp_type:<30} {pts_n:>12,} {100*pts_n/N:>7.1f}%  {list(matching_descs)[:3]}")

comp_counts_audit = pd.Series({pid: len(patient_complications.get(pid, set())) for pid in patient_ids})
print(f"\n📊 COMPLICATION COUNT DISTRIBUTION:")
print(f"   {'# Types':<12} {'N':>8} {'%':>7}")
print("   " + "-" * 30)
for n in range(0, int(comp_counts_audit.max()) + 1):
    cnt = (comp_counts_audit == n).sum()
    pct = 100 * cnt / N
    bar = "█" * int(pct / 2)
    print(f"   {n:<12} {cnt:>8} {pct:>6.1f}%  {bar}")
print(f"   Summary: min={comp_counts_audit.min()}, median={comp_counts_audit.median():.0f}, "
      f"max={comp_counts_audit.max()}, mean={comp_counts_audit.mean():.1f}")

# ── D2: UACR (strict filter) ─────────────────────────────────
print(f"\n{'─' * 70}")
print("🟢 D2 — PROTEINURIA / UACR (Cooper #2, score 8.33)")
print(f"{'─' * 70}")
uacr_obs = obs[obs["DESCRIPTION"].str.contains(
    "Microalbumin Creatinine Ratio", case=False, na=False
)].copy()
uacr_obs["VAL"] = pd.to_numeric(uacr_obs["VALUE"], errors="coerce")
uacr_obs = uacr_obs.dropna(subset=["VAL"])
uacr_max = uacr_obs.groupby("PATIENT")["VAL"].max() if len(uacr_obs) > 0 else pd.Series(dtype=float)

print(f"   Patients with UACR data: {len(uacr_max)}")
if len(uacr_max) > 0:
    print(f"   Per-patient MAX UACR: min={uacr_max.min():.1f}, median={uacr_max.median():.1f}, max={uacr_max.max():.1f}")
    n_normal = (uacr_max < 30).sum()
    n_micro = ((uacr_max >= 30) & (uacr_max < 300)).sum()
    n_macro = (uacr_max >= 300).sum()
    print(f"   Normal (<30):           {n_normal} ({100*n_normal/len(uacr_max):.1f}%)")
    print(f"   Microalbuminuria (30-300): {n_micro} ({100*n_micro/len(uacr_max):.1f}%)")
    print(f"   Macroalbuminuria (>=300):  {n_macro} ({100*n_macro/len(uacr_max):.1f}%)")

# Also show all albumin/protein descriptions found
prot_descs = obs[obs["DESCRIPTION"].str.contains("albumin|protein|uacr|microalbumin", case=False, na=False)]
print(f"\n   All albumin/protein descriptions in data:")
for d in prot_descs["DESCRIPTION"].unique():
    n = prot_descs[prot_descs["DESCRIPTION"] == d]["PATIENT"].nunique()
    print(f"     {n:>5} pts  {d}")

# ── D3: Retinopathy staging ──────────────────────────────────
print(f"\n{'─' * 70}")
print("🟢 D3 — RETINOPATHY (Cooper #3, score 8.25)")
print(f"{'─' * 70}")
ret_patients = {}
for _, row in con[con["DESCRIPTION"].str.contains(
    "retinopathy|macular", case=False, na=False
)].iterrows():
    pid = row["PATIENT"]
    desc = str(row["DESCRIPTION"]).lower()
    if "proliferative" in desc and "nonproliferative" not in desc:
        stage = 3
    elif "macular edema" in desc:
        stage = 3
    elif "nonproliferative" in desc:
        stage = 2
    else:
        stage = 1
    ret_patients[pid] = max(ret_patients.get(pid, 0), stage)

ret_cond = con[con["DESCRIPTION"].str.contains("retinopathy|macular", case=False, na=False)]
print(f"   Retinopathy conditions found:")
for d in ret_cond["DESCRIPTION"].unique():
    n = ret_cond[ret_cond["DESCRIPTION"] == d]["PATIENT"].nunique()
    print(f"     {n:>5} pts  {d}")
print(f"   Total with ANY retinopathy: {len(ret_patients)} ({100*len(ret_patients)/N:.1f}%)")
RET_NAMES = {0: "None", 1: "Generic", 2: "NPDR", 3: "Proliferative/Macular edema"}
for s in [1, 2, 3]:
    cnt = sum(1 for v in ret_patients.values() if v == s)
    print(f"   {RET_NAMES[s]}: {cnt} pts")

# ── D4: Medication intensity ──────────────────────────────────
print(f"\n{'─' * 70}")
print("🟢 D4 — DIABETES MEDICATIONS (Cooper #4, score 8.17)")
print(f"{'─' * 70}")
DM_MED_SEARCH = [
    "metformin", "insulin", "glipizide", "glimepiride", "glyburide",
    "sitagliptin", "saxagliptin", "linagliptin", "alogliptin",
    "empagliflozin", "dapagliflozin", "canagliflozin",
    "semaglutide", "liraglutide", "exenatide", "dulaglutide",
    "pioglitazone", "rosiglitazone", "acarbose", "repaglinide",
    "nateglinide", "pramlintide"
]

DRUG_CLASSES = {
    "Biguanide": ["metformin"],
    "Sulfonylurea": ["glipizide", "glimepiride", "glyburide", "glibenclamide"],
    "DPP-4 inhibitor": ["sitagliptin", "saxagliptin", "linagliptin", "alogliptin"],
    "SGLT2 inhibitor": ["empagliflozin", "dapagliflozin", "canagliflozin"],
    "GLP-1 agonist": ["semaglutide", "liraglutide", "exenatide", "dulaglutide"],
    "Thiazolidinedione": ["pioglitazone", "rosiglitazone"],
    "Insulin": ["insulin"],
    "Meglitinide": ["repaglinide", "nateglinide"],
    "Other": ["acarbose", "pramlintide"],
}

dm_meds = med[med["DESCRIPTION"].str.contains("|".join(DM_MED_SEARCH), case=False, na=False)]

patient_drug_classes = {}
patient_has_insulin = {}
for pid in patient_ids:
    pt_meds = dm_meds[dm_meds["PATIENT"] == pid]["DESCRIPTION"].str.lower()
    classes = set()
    for cls_name, keywords in DRUG_CLASSES.items():
        if pt_meds.str.contains("|".join(keywords), na=False).any():
            classes.add(cls_name)
    patient_drug_classes[pid] = classes
    patient_has_insulin[pid] = "Insulin" in classes

# Show medications found
print(f"\n   Diabetes medications found:")
top_meds = dm_meds.groupby("DESCRIPTION")["PATIENT"].nunique().sort_values(ascending=False)
for m, n in top_meds.head(15).items():
    print(f"     {n:>5} pts ({100*n/N:5.1f}%)  {m}")

class_counts_d4 = pd.Series({pid: len(c) for pid, c in patient_drug_classes.items()})
print(f"\n📊 DRUG CLASS COUNT:")
print(f"   {'# Classes':<12} {'N':>8} {'%':>7}")
print("   " + "-" * 30)
for n in range(0, int(class_counts_d4.max()) + 1):
    cnt = (class_counts_d4 == n).sum()
    bar = "█" * int(100 * cnt / N / 2)
    print(f"   {n:<12} {cnt:>8} {100*cnt/N:>6.1f}%  {bar}")
print(f"   Patients on insulin: {sum(patient_has_insulin.values())} ({100*sum(patient_has_insulin.values())/N:.1f}%)")

# ── D5: Foot ulcer / amputation ───────────────────────────────
print(f"\n{'─' * 70}")
print("🟢 D5 — DIABETIC FOOT ULCER (Cooper #5, score 8.00)")
print(f"{'─' * 70}")
foot_mask = con["DESCRIPTION"].str.contains(
    "foot ulcer|amputation|gangrene|charcot", case=False, na=False
)
foot_patients = set(con[foot_mask]["PATIENT"].unique())
foot_cond = con[foot_mask]
if len(foot_cond) > 0:
    print(f"   Foot-related conditions:")
    for d in foot_cond["DESCRIPTION"].unique():
        n = foot_cond[foot_cond["DESCRIPTION"] == d]["PATIENT"].nunique()
        print(f"     {n:>5} pts  {d}")
print(f"   Total: {len(foot_patients)} pts ({100*len(foot_patients)/N:.1f}%)")

# Check procedures for amputations
if has_procedures:
    amp_procs = proc[proc["DESCRIPTION"].str.contains("amputation", case=False, na=False)]
    if len(amp_procs) > 0:
        print(f"\n   Amputation PROCEDURES:")
        for d in amp_procs["DESCRIPTION"].unique():
            n = amp_procs[amp_procs["DESCRIPTION"] == d]["PATIENT"].nunique()
            print(f"     {n:>5} pts  {d}")

# ── D6: eGFR staging ─────────────────────────────────────────
print(f"\n{'─' * 70}")
print("📊 D6 — eGFR STAGING (Cooper CKD #1, score 9.42)")
print(f"{'─' * 70}")
egfr_obs = obs[obs["DESCRIPTION"].str.contains(
    "glomerular|egfr|gfr", case=False, na=False
)].copy()
egfr_obs["VAL"] = pd.to_numeric(egfr_obs["VALUE"], errors="coerce")
egfr_obs = egfr_obs.dropna(subset=["VAL"])
egfr_min = egfr_obs.groupby("PATIENT")["VAL"].min() if len(egfr_obs) > 0 else pd.Series(dtype=float)

print(f"   eGFR descriptions found:")
for d in egfr_obs["DESCRIPTION"].unique():
    n = egfr_obs[egfr_obs["DESCRIPTION"] == d]["PATIENT"].nunique()
    print(f"     {n:>5} pts  {d}")

if len(egfr_min) > 0:
    print(f"\n   Per-patient MINIMUM eGFR: min={egfr_min.min():.1f}, "
          f"median={egfr_min.median():.1f}, max={egfr_min.max():.1f}")
    stages = {
        "Normal (>=90)":        (egfr_min >= 90).sum(),
        "Mild (60-89)":         ((egfr_min >= 60) & (egfr_min < 90)).sum(),
        "Stage 3a (45-59)":     ((egfr_min >= 45) & (egfr_min < 60)).sum(),
        "Stage 3b (30-44)":     ((egfr_min >= 30) & (egfr_min < 45)).sum(),
        "Stage 4 (15-29)":      ((egfr_min >= 15) & (egfr_min < 30)).sum(),
        "Stage 5/ESRD (<15)":   (egfr_min < 15).sum(),
    }
    print(f"\n   CKD Staging:")
    for stage, cnt in stages.items():
        pct = 100 * cnt / len(egfr_min)
        bar = "█" * int(pct / 2)
        print(f"   {stage:<25} {cnt:>5} ({pct:5.1f}%)  {bar}")

    # Oscillation check
    egfr_std = egfr_obs.groupby("PATIENT")["VAL"].std()
    print(f"\n   eGFR oscillation check:")
    print(f"   Median SD: {egfr_std.median():.1f}")
    print(f"   Patients with SD > 20: {(egfr_std > 20).sum()} ({100*(egfr_std > 20).mean():.1f}%)")

print(f"   D6 eGFR: {len(egfr_min)} patients with data")

# ── D7: HbA1c (sensitivity analysis only) ─────────────────────
print(f"\n{'─' * 70}")
print("🟡 D7 — HbA1c (Cooper AMBER, score 7.58) — SENSITIVITY ONLY")
print(f"{'─' * 70}")
hba1c_obs = obs[obs["DESCRIPTION"].str.contains(
    "a1c|hba1c|hemoglobin a1c|glycated", case=False, na=False
)].copy()
hba1c_obs["VAL"] = pd.to_numeric(hba1c_obs["VALUE"], errors="coerce")
hba1c_obs = hba1c_obs.dropna(subset=["VAL"])
hba1c_max = hba1c_obs.groupby("PATIENT")["VAL"].max() if len(hba1c_obs) > 0 else pd.Series(dtype=float)
hba1c_mean = hba1c_obs.groupby("PATIENT")["VAL"].mean() if len(hba1c_obs) > 0 else pd.Series(dtype=float)
hba1c_std = hba1c_obs.groupby("PATIENT")["VAL"].std() if len(hba1c_obs) > 0 else pd.Series(dtype=float)

print(f"   HbA1c observations: {len(hba1c_obs):,}")
print(f"   Patients with HbA1c: {len(hba1c_max)}")

if len(hba1c_max) > 0:
    print(f"\n   ALL values: min={hba1c_obs['VAL'].min():.1f}%, "
          f"median={hba1c_obs['VAL'].median():.1f}%, max={hba1c_obs['VAL'].max():.1f}%")

    print(f"\n   Per-patient MAX HbA1c:")
    print(f"   < 5.7%:    {(hba1c_max < 5.7).sum()} pts ({100*(hba1c_max < 5.7).mean():.1f}%) - normal range")
    print(f"   5.7-6.4%:  {((hba1c_max >= 5.7) & (hba1c_max < 6.5)).sum()} pts - pre-diabetic")
    print(f"   6.5-7.4%:  {((hba1c_max >= 6.5) & (hba1c_max < 7.5)).sum()} pts - diabetic, controlled")
    print(f"   7.5-9.9%:  {((hba1c_max >= 7.5) & (hba1c_max < 10)).sum()} pts - suboptimal")
    print(f"   >= 10%:    {(hba1c_max >= 10).sum()} pts - poor control")

    print(f"\n   Variability check:")
    print(f"   Median SD: {hba1c_std.median():.2f}")
    n_static = (hba1c_std < 0.5).sum()
    n_with_std = len(hba1c_std.dropna())
    print(f"   Static (SD < 0.5): {n_static}/{n_with_std} ({100*n_static/n_with_std:.1f}%)")

    # Implausible values check
    n_below_3 = (hba1c_obs["VAL"] < 3.0).sum()
    n_pts_below_3 = hba1c_obs[hba1c_obs["VAL"] < 3.0]["PATIENT"].nunique()
    print(f"   Values < 3.0% (clinically implausible for T2D): {n_below_3} readings ({n_pts_below_3} patients)")

print(f"   D7 HbA1c: {len(hba1c_max)} patients with data (sensitivity only)")

# ── Build dimension table ─────────────────────────────────────
dim = pd.DataFrame(index=patient_ids)
dim.index.name = "PATIENT_ID"

dim["comp_count"] = pd.Series({pid: len(patient_complications.get(pid, set())) for pid in patient_ids})
dim["comp_types"] = pd.Series({pid: ", ".join(sorted(patient_complications.get(pid, set()))) or "none" for pid in patient_ids})
dim["uacr_max"] = dim.index.map(uacr_max)
dim["retinopathy_stage"] = dim.index.map(pd.Series(ret_patients)).fillna(0).astype(int)
dim["has_insulin"] = pd.Series(patient_has_insulin)
dim["drug_classes"] = pd.Series({pid: len(c) for pid, c in patient_drug_classes.items()})
dim["foot_ulcer"] = dim.index.isin(foot_patients)
dim["egfr_min"] = dim.index.map(egfr_min)
dim["hba1c_max"] = dim.index.map(hba1c_max)
dim["hba1c_mean"] = dim.index.map(hba1c_mean)
dim["hba1c_std"] = dim.index.map(hba1c_std)

print(f"\n   Dimension table: {dim.shape[0]} patients × {dim.shape[1]} dimensions")
print(f"   Missing values:")
print(dim.isnull().sum().to_string())


# ══════════════════════════════════════════════════════════════
# STEP 2: CLASSIFICATION FUNCTIONS
# ══════════════════════════════════════════════════════════════
print(f"\n{'=' * 70}")
print("📊 STEP 2 — Classifying patients")
print("=" * 70)

RET_NAMES = {0: "None", 1: "Generic", 2: "NPDR", 3: "Proliferative/Macular edema"}

def classify_patient(row, include_hba1c=False):
    """
    Classify a patient into four tiers + binary.
    Returns: (four_tier, binary, tier_reason, evidence_str)
    """
    comp_count = int(row.get("comp_count", 0))
    egfr = row.get("egfr_min")
    egfr_ok = pd.notna(egfr)
    uacr = row.get("uacr_max")
    uacr_ok = pd.notna(uacr)
    insulin = bool(row.get("has_insulin", False))
    drug_cls = int(row.get("drug_classes", 0))
    ret_stage = int(row.get("retinopathy_stage", 0))
    foot = bool(row.get("foot_ulcer", False))
    hba1c = row.get("hba1c_max")
    hba1c_ok = pd.notna(hba1c) and include_hba1c

    # ── Build evidence string ─────────────────────────────────
    parts = []
    parts.append(f"Complications: {comp_count} types ({row.get('comp_types', 'none')})")
    if egfr_ok:
        if egfr >= 90: ckd = "Normal"
        elif egfr >= 60: ckd = "Mild CKD"
        elif egfr >= 45: ckd = "Stage 3a"
        elif egfr >= 30: ckd = "Stage 3b"
        elif egfr >= 15: ckd = "Stage 4"
        else: ckd = "Stage 5/ESRD"
        parts.append(f"eGFR min: {egfr:.1f} ({ckd})")
    else:
        parts.append("eGFR: MISSING")
    if uacr_ok:
        if uacr < 30: us = "Normal"
        elif uacr < 300: us = "Microalbuminuria"
        else: us = "Macroalbuminuria"
        parts.append(f"UACR max: {uacr:.1f} mg/g ({us})")
    else:
        parts.append("UACR: MISSING")
    parts.append(f"Retinopathy: {RET_NAMES.get(ret_stage, 'Unknown')}")
    if insulin:
        parts.append(f"Treatment: Insulin + {drug_cls - 1 if drug_cls > 1 else 0} other class(es)")
    elif drug_cls > 0:
        parts.append(f"Treatment: {drug_cls} oral class(es), no insulin")
    else:
        parts.append("Treatment: No DM medications")
    if foot:
        parts.append("Foot ulcer/amputation: YES")
    if hba1c_ok:
        parts.append(f"HbA1c max: {hba1c:.1f}%")
    evidence = " | ".join(parts)

    # ── CRITICAL-COMPLEX (check first) ────────────────────────
    critical_reasons = []
    if egfr_ok and egfr < 15 and comp_count >= 2:
        critical_reasons.append(f"ESRD (eGFR {egfr:.1f}) + {comp_count} complication types")
    if comp_count >= 4 and egfr_ok and egfr < 30:
        critical_reasons.append(f"{comp_count} complication types + advanced CKD (eGFR {egfr:.1f})")
    if comp_count >= 3 and egfr_ok and egfr < 30 and insulin:
        critical_reasons.append(f"{comp_count} complications + CKD Stage 4-5 + insulin")
    if foot and comp_count >= 2:
        critical_reasons.append(f"Foot ulcer/amputation + {comp_count} complication types")
    # HbA1c contribution to Critical (sensitivity only)
    if hba1c_ok and hba1c > 12.0 and comp_count >= 2:
        critical_reasons.append(f"HbA1c {hba1c:.1f}% (>12) + {comp_count} complications")

    if critical_reasons:
        reason = "Critical because: " + "; ".join(critical_reasons)
        return "Critical-Complex", "SEVERE", reason, evidence

    # ── SEVERE ────────────────────────────────────────────────
    severe_reasons = []
    if comp_count >= 3:
        severe_reasons.append(f"{comp_count} distinct complication types (>=3)")
    if egfr_ok and egfr < 30:
        severe_reasons.append(f"eGFR {egfr:.1f} - CKD Stage 4+ (<30)")
    if ret_stage >= 3:
        severe_reasons.append("Proliferative retinopathy or macular edema")
    if uacr_ok and uacr >= 300:
        severe_reasons.append(f"Macroalbuminuria (UACR {uacr:.1f} mg/g)")
    # HbA1c contribution to Severe (sensitivity only)
    if hba1c_ok and hba1c >= 10.0:
        severe_reasons.append(f"HbA1c {hba1c:.1f}% (>=10)")

    if severe_reasons:
        reason = "Severe because: " + "; ".join(severe_reasons)
        return "Severe", "SEVERE", reason, evidence

    # ── MILD ──────────────────────────────────────────────────
    is_mild = True
    mild_fails = []
    if comp_count > 1:
        is_mild = False
        mild_fails.append(f"comp_count={comp_count} (>1)")
    if egfr_ok and egfr < 60:
        is_mild = False
        mild_fails.append(f"eGFR={egfr:.1f} (<60)")
    if uacr_ok and uacr >= 30:
        is_mild = False
        mild_fails.append(f"UACR={uacr:.1f} (>=30)")
    if ret_stage > 0:
        is_mild = False
        mild_fails.append(f"retinopathy stage {ret_stage}")
    if foot:
        is_mild = False
        mild_fails.append("foot ulcer/amputation")
    if insulin:
        is_mild = False
        mild_fails.append("on insulin")
    # HbA1c contribution to Mild exclusion (sensitivity only)
    if hba1c_ok and hba1c >= 7.5:
        is_mild = False
        mild_fails.append(f"HbA1c={hba1c:.1f}% (>=7.5)")

    if is_mild:
        reason = "Mild: <=1 complication, eGFR >=60, normal UACR, no retinopathy, no insulin, no foot ulcer"
        if include_hba1c:
            reason += ", HbA1c <7.5%"
        return "Mild", "NOT_SEVERE", reason, evidence

    # ── MODERATE (everything else) ────────────────────────────
    reason = "Moderate: exceeds Mild criteria (" + ", ".join(mild_fails) + ") but does not meet Severe/Critical thresholds"
    return "Moderate", "NOT_SEVERE", reason, evidence


# ── Run all four classifications ──────────────────────────────
print("\n   Classifying...")

results = []
for pid in patient_ids:
    row = dim.loc[pid]

    # Primary (WITH HbA1c — matches Cooper et al. full phenotype set)
    ft_p, bin_p, reason_p, evidence_p = classify_patient(row, include_hba1c=True)
    # Sensitivity (WITHOUT HbA1c — tests impact of excluding artefactual dimension)
    ft_s, bin_s, reason_s, evidence_s = classify_patient(row, include_hba1c=False)

    results.append({
        "PATIENT_ID": pid,
        # Dimensions
        "COMP_COUNT": int(row["comp_count"]),
        "COMP_TYPES": row["comp_types"],
        "EGFR_MIN": round(row["egfr_min"], 1) if pd.notna(row["egfr_min"]) else "MISSING",
        "UACR_MAX": round(row["uacr_max"], 1) if pd.notna(row["uacr_max"]) else "MISSING",
        "RETINOPATHY": RET_NAMES.get(int(row["retinopathy_stage"]), "Unknown"),
        "HAS_INSULIN": bool(row["has_insulin"]),
        "DRUG_CLASSES": int(row["drug_classes"]),
        "FOOT_ULCER": bool(row["foot_ulcer"]),
        "HBA1C_MAX": round(row["hba1c_max"], 1) if pd.notna(row["hba1c_max"]) else "MISSING",
        "HBA1C_MEAN": round(row["hba1c_mean"], 1) if pd.notna(row["hba1c_mean"]) else "MISSING",
        "HBA1C_SD": round(row["hba1c_std"], 2) if pd.notna(row["hba1c_std"]) else "MISSING",
        "HBA1C_VARIABILITY": (
            "STATIC" if pd.notna(row["hba1c_std"]) and row["hba1c_std"] < 0.1
            else "NEAR-STATIC" if pd.notna(row["hba1c_std"]) and row["hba1c_std"] < 0.5
            else "VARIABLE" if pd.notna(row["hba1c_std"])
            else "NO DATA"
        ),
        # Primary (WITH HbA1c — matches Cooper)
        "FOUR_TIER": ft_p,
        "BINARY": bin_p,
        "TIER_REASON": reason_p,
        "FULL_EVIDENCE": evidence_p,
        # Sensitivity (WITHOUT HbA1c — artefact impact test)
        "FOUR_TIER_SENSITIVITY": ft_s,
        "BINARY_SENSITIVITY": bin_s,
        "TIER_REASON_SENSITIVITY": reason_s,
        "FULL_EVIDENCE_SENSITIVITY": evidence_s,
        # Did removing HbA1c change the classification?
        "HBAC1_CHANGED_TIER": ft_p != ft_s,
        "HBAC1_CHANGED_BINARY": bin_p != bin_s,
    })

results_df = pd.DataFrame(results)
print(f"   ✅ Classified {len(results_df)} patients")


